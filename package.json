{
  "name": "jazz-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run --workspace @jazz/web dev",
    "dev:api": "npm run --workspace @jazz/api start:dev",
    "dev:socket": "npm run --workspace @jazz/socket dev",
    "build": "npm run build --workspace @jazz/api && npm run build --workspace @jazz/socket && npm run build --workspace @jazz/web",
    "lint": "npm run lint --workspace @jazz/web && npm run lint --workspace @jazz/api",
    "prisma:generate": "npm run --workspace @jazz/api prisma:generate",
    "prisma:migrate": "npm run --workspace @jazz/api prisma:migrate"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "firebase": "^12.12.0"
  }
}
