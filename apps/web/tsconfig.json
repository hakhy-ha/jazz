{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@jazz/ui": [
        "../../packages/ui/src"
      ],
      "@jazz/types": [
        "../../packages/types/src"
      ],
      "@jazz/utils": [
        "../../packages/utils/src"
      ]
    },
    "noEmit": true,
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
